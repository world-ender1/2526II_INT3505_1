{
  "info": {
    "name": "SOA Week2 - Client-Server, Uniform Interface, Stateless, Cacheable",
    "description": "Collection to test week2 REST constraints implementation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "A. Client-Server",
      "item": [
        {
          "name": "1) Health check root",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
      "name": "B. Uniform Interface",
      "item": [
        {
          "name": "2) GET /tasks (collection)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            }
          }
        },
        {
          "name": "3) POST /tasks (create)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Week2 uniform interface demo\",\n  \"done\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('task_id', body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "4) GET /tasks/:id (item)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["tasks", "{{task_id}}"]
            }
          }
        },
        {
          "name": "5) PUT /tasks/:id (replace)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Week2 replaced title\",\n  \"done\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["tasks", "{{task_id}}"]
            }
          }
        },
        {
          "name": "6) PATCH /tasks/:id (partial update)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Week2 patched title\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["tasks", "{{task_id}}"]
            }
          }
        },
        {
          "name": "7) DELETE /tasks/:id",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["tasks", "{{task_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "C. Stateless",
      "item": [
        {
          "name": "8) GET /tasks without X-Client-Id (expect 400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            }
          }
        },
        {
          "name": "9) GET /tasks with X-Client-Id (expect 200)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            }
          }
        }
      ]
    },
    {
      "name": "D. Cacheable",
      "item": [
        {
          "name": "10) GET /tasks first time (save ETag)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const etag = pm.response.headers.get('ETag');",
                  "if (etag) pm.collectionVariables.set('tasks_etag', etag);"
                ]
              }
            }
          ]
        },
        {
          "name": "11) GET /tasks with If-None-Match (expect 304)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              },
              {
                "key": "If-None-Match",
                "value": "{{tasks_etag}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            }
          }
        },
        {
          "name": "12) POST /tasks to change data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cache invalidation demo\",\n  \"done\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            }
          }
        },
        {
          "name": "13) GET /tasks with old If-None-Match (expect 200 + new ETag)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Client-Id",
                "value": "client-A"
              },
              {
                "key": "If-None-Match",
                "value": "{{tasks_etag}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000"
    },
    {
      "key": "task_id",
      "value": "1"
    },
    {
      "key": "tasks_etag",
      "value": ""
    }
  ]
}
